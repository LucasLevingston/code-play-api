#!/bin/bash

# Pre-commit hook - Roda testes antes de commit
# Uso: cp scripts/pre-commit .git/hooks/ && chmod +x .git/hooks/pre-commit

echo "Rodando verificacoes antes de commit..."

echo "[1/2] Type check..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
    echo "Erros de tipagem encontrados. Commit cancelado."
    echo "Use 'git commit --no-verify' para pular (nao recomendado)"
    exit 1
fi

echo "[2/2] Testes..."
npm test
if [ $? -ne 0 ]; then
    echo "Testes falharam. Commit cancelado."
    echo "Use 'git commit --no-verify' para pular (nao recomendado)"
    exit 1
fi

echo "Tudo certo! Commit liberado."
exit 0
