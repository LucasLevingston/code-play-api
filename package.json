{
	"name": "code-play-api",
	"description": "",
	"version": "1.0.0",
	"main": "server.ts",
	"engines": {
		"node": "22"
	},
	"_moduleAliases": {
		"@": "dist"
	},
	"scripts": {
		"dev": "tsx --env-file .env --watch src/server.ts",
		"start": "tsx src/server.ts",
		"pretest": "dotenv -e .env.test prisma db push",
		"test": "dotenv -e .env.test vitest run",
		"test:watch": "dotenv -e .env.test vitest watch",
		"seed": "prisma generate && tsx --env-file .env prisma/seed.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/bcrypt": "^6.0.0",
