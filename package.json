		"fastify": "^5.8.5",
		"fastify-type-provider-zod": "^6.1.0",
		"jsonwebtoken": "^9.0.3",
		"mongodb": "^7.2.0",
		"pg": "^8.20.0",
		"prisma": "^6.19.3",
		"ts-node-dev": "^2.0.0",
		"tsx": "^4.21.0",
		"zod": "^4.4.3"
	}
