{
	"compilerOptions": {
		"target": "es2020",
		"module": "CommonJS",
		"rootDir": "src",
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": ["node"],
		"typeRoots": ["./src/@types", "./node_modules/@types"],
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"outDir": "dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"strictNullChecks": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
